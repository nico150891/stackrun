{
  "name": "@nico0891/stackrun",
  "version": "0.2.0",
  "description": "Universal CLI to install, authenticate and execute SaaS tools from terminal",
  "main": "dist/index.js",
  "bin": {
    "stackrun": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nico150891/stackrun.git"
  },
  "homepage": "https://github.com/nico150891/stackrun",
  "bugs": {
    "url": "https://github.com/nico150891/stackrun/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "dev": "ts-node --esm src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "saas",
    "api",
    "developer-tools"
  ],
  "author": "nico150891",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
