{
  "name": "notion",
  "version": "1.0.0",
  "description": "Notion workspace API",
  "base_url": "https://api.notion.com/v1",
  "auth": {
    "type": "bearer",
    "header": "Authorization",
    "prefix": "Bearer"
  },
  "headers": {
    "Notion-Version": "2022-06-28"
  },
  "commands": [
    {
      "name": "list_databases",
      "method": "POST",
      "path": "/search",
      "description": "Search all databases in the workspace",
      "headers": {
        "Content-Type": "application/json"
      }
    },
    {
      "name": "list_users",
      "method": "GET",
      "path": "/users",
      "description": "List all users in the workspace"
    }
  ]
}
